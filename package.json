{
  "name": "smb-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm --workspace server run dev",
    "db:migrate": "npm --workspace server run db:migrate",
    "build": "tsc --noEmit && vite build && npm --workspace server run build",
    "preview": "vite preview",
    "test": "rm -rf .test-build && tsc -p tsconfig.test.json && node --test tests/*.test.mjs && npm --workspace server test",
    "test:web": "rm -rf .test-build && tsc -p tsconfig.test.json && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit --pretty && npm --workspace server run typecheck"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
